{
  "name": "argo-app",
  "private": true,
  "version": "0.1.0",
  "description": "Argo desktop shell (Vite + React + Electron)",
  "author": "Argo contributors",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "kill:dev-port": "lsof -tiTCP:5173 -sTCP:LISTEN | xargs kill 2>/dev/null || true",
    "dev": "npm run build:electron && node ./node_modules/concurrently/dist/bin/concurrently.js -k \"node ./node_modules/vite/bin/vite.js\" \"node ./node_modules/typescript/bin/tsc -p tsconfig.electron.json --watch\" \"node ./node_modules/typescript/bin/tsc -p tsconfig.electron-preload.json --watch\" \"node ./node_modules/wait-on/bin/wait-on -l -t 120000 http-get://127.0.0.1:5173/ && node ./node_modules/cross-env/src/bin/cross-env.js NODE_ENV=development node ./node_modules/electron/cli.js .\"",
    "build:electron": "node ./node_modules/typescript/bin/tsc -p tsconfig.electron.json && node ./node_modules/typescript/bin/tsc -p tsconfig.electron-preload.json",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "package:mac": "npm run build && npm run build:electron && node ./node_modules/electron-builder/cli.js --mac",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "test:phase01": "npm run build:electron && node dist-electron/scripts/verify-phase01.js",
    "test:phase02": "npm run build:electron && node dist-electron/scripts/verify-phase02.js",
    "test:phase03": "npm run build:electron && node dist-electron/scripts/verify-phase03.js",
    "test:phase04": "npm run build:electron && node dist-electron/scripts/verify-phase04.js",
    "test:phase05": "npm run build:electron && node dist-electron/scripts/verify-phase05.js",
    "test:phase06": "npm run build:electron && node dist-electron/scripts/verify-phase06.js"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.6.2",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.argo.desktop",
    "productName": "Argo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false
    }
  }
}
